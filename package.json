{
  "name": "ai-json-repair",
  "version": "0.0.1",
  "description": "TypeScript port of mangiucugna/json_repair",
  "keywords": [
    "json",
    "repair",
    "parser",
    "schema",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kevin51jiang/json-repair#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevin51jiang/json-repair.git"
  },
  "bugs": {
    "url": "https://github.com/kevin51jiang/json-repair/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "json-repair": "./dist/bin.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts",
    "check": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
