{
  "name": "ai-json-repair",
  "version": "0.0.1",
  "description": "TypeScript port of mangiucugna/json_repair",
  "keywords": [
    "json",
    "repair",
    "parser",
    "schema",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kevin51jiang/json-repair#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevin51jiang/json-repair.git"
  },
  "bugs": {
    "url": "https://github.com/kevin51jiang/json-repair/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "json-repair": "./dist/bin.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts",
    "check": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
